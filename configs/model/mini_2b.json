{
  "model_type": "deepseek_v4",
  "vocab_size": 129280,
  "hidden_size": 1536,
  "num_hidden_layers": 12,
  "num_attention_heads": 16,
  "num_key_value_heads": 1,
  "head_dim": 128,
  "qk_rope_head_dim": 32,
  "max_position_embeddings": 4096,
  "rms_norm_eps": 1e-6,
  "initializer_range": 0.02,

  "q_lora_rank": 768,
  "o_lora_rank": 384,
  "o_groups": 4,
  "sliding_window": 64,
  "attention_bias": false,
  "attention_dropout": 0.0,

  "compress_ratios": [128, 128, 4, 128, 4, 128, 4, 128, 4, 128, 4, 0],
  "compress_rope_theta": 160000.0,

  "index_n_heads": 8,
  "index_head_dim": 64,
  "index_topk": 128,

  "rope_theta": 10000.0,
  "rope_scaling": {
    "beta_fast": 32,
    "beta_slow": 1,
    "factor": 4,
    "original_max_position_embeddings": 1024,
    "type": "yarn"
  },

  "moe_intermediate_size": 768,
  "n_routed_experts": 32,
  "n_shared_experts": 1,
  "num_experts_per_tok": 4,
  "num_hash_layers": 1,
  "norm_topk_prob": true,
  "scoring_func": "sqrtsoftplus",
  "routed_scaling_factor": 2.5,
  "hidden_act": "silu",
  "swiglu_limit": 10.0,

  "hc_mult": 4,
  "hc_sinkhorn_iters": 10,
  "hc_eps": 1e-6,

  "bos_token_id": 0,
  "eos_token_id": 1,
  "pad_token_id": 2,
  "use_cache": true,
  "tie_word_embeddings": false
}
